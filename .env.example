# Instagram Reel Downloader Configuration
# Copy this file to .env and configure for your environment

# ═══════════════════════════════════════════════════════════
# API SECURITY (REQUIRED FOR PRODUCTION)
# ═══════════════════════════════════════════════════════════
# Generate a strong random key for production use
# Example: openssl rand -hex 32
INSTAGRAM_API_KEY=2e7e08e1e7f078ab97b325dc8e3b311b1663edb9eb11d907a553238ead00c8b0

# ═══════════════════════════════════════════════════════════
# SERVER SETTINGS
# ═══════════════════════════════════════════════════════════
# Host address (0.0.0.0 for all interfaces, required for Render)
FLASK_HOST=0.0.0.0

# Port (Render will set PORT automatically)
FLASK_PORT=5000

# Debug mode (false for production)
FLASK_DEBUG=false

# ═══════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════
# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW=60

# Maximum requests per IP per time window
RATE_LIMIT_MAX=30

# ═══════════════════════════════════════════════════════════
# REQUEST SETTINGS
# ═══════════════════════════════════════════════════════════
# Maximum allowed URL length
MAX_URL_LENGTH=500

# Request timeout in seconds
REQUEST_TIMEOUT=30

# ═══════════════════════════════════════════════════════════
# YT-DLP SETTINGS
# ═══════════════════════════════════════════════════════════
# Timeout for yt-dlp extraction
YTDLP_TIMEOUT=30

# Number of retries for failed extractions
YTDLP_RETRIES=3

# ═══════════════════════════════════════════════════════════
# STREAMING SETTINGS
# ═══════════════════════════════════════════════════════════
# Chunk size for streaming (bytes)
CHUNK_SIZE=8192

# Buffer size for streams (bytes)
STREAM_BUFFER_SIZE=65536